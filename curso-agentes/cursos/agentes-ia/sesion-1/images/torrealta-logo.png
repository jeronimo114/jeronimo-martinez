.CardProgramacion {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.21);
  border: 1px solid rgba(255, 255, 255, 1);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(8.7px);
  -webkit-backdrop-filter: blur(8.7px);
  cursor: pointer;
  transition:
    transform 0.6s ease,
    box-shadow 0.6s ease,
    border-color 0.6s ease;
}

/* === Contenido interno === */
.CardProgramacion > * {
  position: relative;
  z-index: 3;
  color: #fff;
  transition: color 0.3s ease;
}

/* === Capa animada del degradado === */
.CardProgramacion::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(
    -45deg,
    #2a3699,
    #5663c8,
    #5bc6f1,
    #aad8ef,
    #5663c8,
    #2a3699
  );
  background-size: 500% 500%;
  opacity: 0;
  z-index: 1;
  transition: opacity 0.8s ease;
}

/* === Halo brillante interno === */
.CardProgramacion::after {
  content: "";
  position: absolute;
  inset: -2px;
  border-radius: inherit;
  background: radial-gradient(
    circle at center,
    rgba(255, 255, 255, 0.35),
    transparent 60%
  );
  opacity: 0;
  z-index: 2;
  transition: opacity 0.8s ease;
}

/* === Hover === */
.CardProgramacion:hover {
  transform: translateY(-6px) scale(1.03);
  border-color: rgba(255, 255, 255, 0.5);
  box-shadow: 0 12px 45px rgba(0, 0, 0, 0.4);
}

.CardProgramacion:hover::before {
  opacity: 1;
  animation: waveGradient 6s ease-in-out infinite;
}

.CardProgramacion:hover::after {
  opacity: 1;
  animation: pulseGlow 3s ease-in-out infinite;
}

/* === Animación de ondas === */
@keyframes waveGradient {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* === Brillo pulsante === */
@keyframes pulseGlow {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}
































